@page
@model LoginModel
@{
    ViewData["Title"] = "Customer Login";
}

<div class="identity-wrapper">
    <div class="identity-card">
        <h1>@ViewData["Title"]</h1>
        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="text-dark">Email</label>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="password" />
                <label asp-for="Input.Password" class="text-dark">Password</label>
            </div>
            
            <div class="checkbox mb-3 text-center">
                <label asp-for="Input.RememberMe" class="form-label">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
            </div>
            
            <button id="login-submit" type="submit" class="w-100 btn-submit">Log in</button>
            
            <div class="mt-3 text-center">
                <p><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-info">Register as a new user</a></p>
            </div>
        </form>
    </div>
</div>