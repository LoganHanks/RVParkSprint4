@page
@model RVPark_Team2.Pages.Reservations.CreateModel
@{
    ViewData["Title"] = "Make a Reservation";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/reservation-create.css" />
}

<div class="reservation-container">
    <h1>Make a Reservation</h1>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form method="post" class="reservation-form">
        <div class="form-group">
            <label asp-for="Reservation.CustomerName">Full Name</label>
            <input asp-for="Reservation.CustomerName" />
            <span asp-validation-for="Reservation.CustomerName" class="field-validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Reservation.CustomerEmail">Email</label>
            <input asp-for="Reservation.CustomerEmail" type="email" />
            <span asp-validation-for="Reservation.CustomerEmail" class="field-validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Reservation.StartDate">Check-In Date</label>
            <input asp-for="Reservation.StartDate" type="date" />
            <span asp-validation-for="Reservation.StartDate" class="field-validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Reservation.EndDate">Check-Out Date</label>
            <input asp-for="Reservation.EndDate" type="date" />
            <span asp-validation-for="Reservation.EndDate" class="field-validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Reservation.SiteId">Campsite</label>
            <select asp-for="Reservation.SiteId" asp-items="Model.SiteOptions">
                <option value="">Select a campsite</option>
            </select>
            <span asp-validation-for="Reservation.SiteId" class="field-validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Reservation.VehicleLength">Vehicle Length (if applicable)</label>
            <input asp-for="Reservation.VehicleLength" type="number" min="0" />
            <span asp-validation-for="Reservation.VehicleLength" class="field-validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Reservation.NumberOfAdults">Number of Adults</label>
            <input asp-for="Reservation.NumberOfAdults" type="number" min="1" />
            <span asp-validation-for="Reservation.NumberOfAdults" class="field-validation"></span>
        </div>

        <div class="form-group checkbox-group">
            <label>
                <input asp-for="Reservation.Pets" />
                Bringing Pets
            </label>
        </div>

        <div class="form-group">
            <label asp-for="Reservation.SpecialRequests">Special Requests</label>
            <textarea asp-for="Reservation.SpecialRequests" rows="4"></textarea>
            <span asp-validation-for="Reservation.SpecialRequests" class="field-validation"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="reserve-btn">Reserve Now</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
