@page
@model RVPark_Team2.Pages.Admin.Sites.IndexModel
@{
    ViewData["Title"] = "Manage Reservations";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin-site.css" />
}



<!--


    Will Need to create, edit, delete RV sites
    Will need to control site types and photos

    Can assign multiple photos to a site

    new sites have site number and type

-->
@if (TempData["SuccessMessage"] != null)
{
    <div class="toast-success" id="successToast">
        <span>@TempData["SuccessMessage"]</span>
        <button type="button" class="toast-close" onclick="closeToast()">×</button>
    </div>
}

<div class="sites-container">
    <h1>Manage Sites</h1>

    <form method="get" class="search-sites-form">
        <input type="text" name="SearchSiteNumber" value="@Model.SearchSiteNumber" placeholder="Search Site by Site Number"/>
        <button type="submit">Search</button>
    </form>

    <form method="post">
        <button type="submit" class="btn btn-primary">Add Site</button>
    </form>

    @if (Model.Sites != null && Model.Sites.Any())
    {
        <div class="sitesTable">
            <div class="table-header">
                <span>ID</span>
                <span>SiteNumber</span>
                <span>SiteTypeID</span>
                <span>Actions</span>
            </div>

            @foreach (var s in Model.Sites)
            {
                <div class="table-row">
                    <span>@s.Id</span>
                    <span>@s.SiteNumber</span>
                    <span>@s.SiteTypeId</span>
                    <span>
                        <a asp-page="Edit" asp-route-id="@s.Id">Edit</a>
                        
                        <form method="post" asp-page-handler="Delete" asp-route-id="@s.Id" style="display:inline;">
                            <button type="submit" onclick="return confirm('Are you sure you want to delete this site?');" class="btn btn-danger">Delete</button>
                        </form>
                    </span>
                    
                    
                </div>
            }
        </div>
    }
    else
    {
        <p>No reservations found</p>
    }
</div>

<script>
    function closeToast() {
        const toast = document.getElementById("successToast");
        if (toast) {
            toast.style.animation = "fadeOut 0.3s ease forwards";
            setTimeout(() => toast.remove(), 300);
        }
    }

    // Auto-dismiss after 3 seconds
    setTimeout(() => {
        const toast = document.getElementById("successToast");
        if (toast) {
            toast.style.animation = "fadeOut 0.3s ease forwards";
            setTimeout(() => toast.remove(), 300);
        }
    }, 3000);
</script>