@page "{id:int}"
@model RVPark_Team2.Pages.Admin.Sites.EditModel
@{
	ViewData["Title"] = "Edit Site";
}

@section Styles {
	<link rel="stylesheet" href="~/css/pages/admin-site.css" />
}

<div class="edit-container">

	<h1>Edit Site</h1>

	<div class="return-container">
		<a asp-page="Index" class="return-btn">Return to Sites</a>
	</div>

	<form method="post" asp-page-handler="Save" class="edit-form">

		<input type="hidden" asp-for="Site.Id" />
		<div class="form-group">
			<label asp-for="Site.SiteNumber">Site Number</label>
			<input asp-for="Site.SiteNumber" />
			<span asp-validation-for="Site.SiteNumber" class="field-validation"></span>
		</div>
		<div class="form-group">
			<label asp-for="Site.SiteTypeId">Site Type ID</label>
			<select asp-for="Site.SiteTypeId" asp-items="Model.SiteTypes"></select>
			<span asp-validation-for="Site.SiteTypeId" class="field-validation"></span>
		</div>
		
		<div class="form-actions">
			<button type="submit" class="save-btn">Save Changes</button>
		</div>
	</form>

	@if (Model.Photos != null && Model.Photos.Any())
	{
		<div class="photos-section">
			<h2>Site Photos</h2>
			<div class="photos-grid">
				@foreach (var photo in Model.Photos)
				{
					<div class="photo-card">
						<img src="@photo.PhotoUrl" alt="Site Photo" />
						<form method="post" asp-page-handler="DeletePhoto" asp-route-id="@photo.Id" style="display:inline;">
							<button type="submit" onclick="return confirm('Are you sure you want to delete this photo?');" class="btn btn-danger">Delete</button>
						</form>
					</div>
				}
			</div>
		</div>
	}

	<div class="add-photo-section">
		<h2>Add New Photo</h2>
		<form method="post" enctype="multipart/form-data" asp-page-handler="AddPhoto">
			<input type="file" name="PhotoFile" accept="image/*" required />
			<button type="submit" class="save-btn">Upload Photo</button>
		</form>
	</div>

</div>