@page
@model RVPark_Team2.Pages.Admin.Employees.DeleteModel

@{
    ViewData["Title"] = "Delete Employee";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin-employees.css" />
}

<div class="edit-container">
    <h1>Delete Employee</h1>

    <h3>Are you sure you want to delete this?</h3>

    <hr />

    <dl class="details-list">
        <dt>@Html.DisplayNameFor(model => model.Employee.FirstName)</dt>
        <dd>@Html.DisplayFor(model => model.Employee.FirstName)</dd>

        <dt>@Html.DisplayNameFor(model => model.Employee.LastName)</dt>
        <dd>@Html.DisplayFor(model => model.Employee.LastName)</dd>

        <dt>@Html.DisplayNameFor(model => model.Employee.Email)</dt>
        <dd>@Html.DisplayFor(model => model.Employee.Email)</dd>

        <dt>@Html.DisplayNameFor(model => model.Employee.AccessLevel)</dt>
        <dd>@Html.DisplayFor(model => model.Employee.AccessLevel)</dd>

        <dt>@Html.DisplayNameFor(model => model.Employee.IsLocked)</dt>
        <dd>@Html.DisplayFor(model => model.Employee.IsLocked)</dd>
    </dl>

    <div class="return-container">
        <form method="post" style="display: inline;">
            <input type="hidden" asp-for="Employee.Id" />
            <button type="submit" class="btn-danger">Delete</button>
        </form>

        <a class="return-btn" asp-page="Index">Back to List</a>
    </div>
</div>