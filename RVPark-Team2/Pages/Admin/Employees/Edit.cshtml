@page
@model RVPark_Team2.Pages.Admin.Employees.EditModel

@{
    ViewData["Title"] = "Edit Employee";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin-employees.css" />
}

<div class="edit-container">
    <h1>Edit Employee</h1>

    <h4>Employee</h4>
    <hr />

    <div class="return-container">
        <a class="return-btn" asp-page="Index">Back to List</a>
    </div>

    <form method="post" class="edit-form">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <input type="hidden" asp-for="Employee.Id" />

        <div class="form-group">
            <label asp-for="Employee.FirstName"></label>
            <input asp-for="Employee.FirstName" />
            <span asp-validation-for="Employee.FirstName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Employee.LastName"></label>
            <input asp-for="Employee.LastName" />
            <span asp-validation-for="Employee.LastName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Employee.Email"></label>
            <input asp-for="Employee.Email" />
            <span asp-validation-for="Employee.Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Employee.AccessLevel"></label>
            <input asp-for="Employee.AccessLevel" />
            <span asp-validation-for="Employee.AccessLevel" class="text-danger"></span>
        </div>

        <div class="form-group form-check">
            <label class="form-check-label">
                <input class="form-check-input" asp-for="Employee.IsLocked" /> @Html.DisplayNameFor(model => model.Employee.IsLocked)
            </label>
        </div>

        <div class="form-group">
            <input type="submit" value="Save" class="save-btn" />
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}