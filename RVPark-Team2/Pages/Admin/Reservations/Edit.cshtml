@page "{id:int}"
@model RVPark_Team2.Pages.Admin.Reservations.EditModel

@{
    ViewData["Title"] = "Edit Reservation";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin-edit-reservation.css" />
}

<div class="edit-container">

    <h1>Edit Reservation</h1>

    <div class="form-actions">
        <a asp-page="Index" class="back-btn">← Return to Reservations</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="price-change">
            <strong>@Model.StatusMessage</strong>
        </div>
    }

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form method="post" class="edit-form">

        <input type="hidden" asp-for="Reservation.Id" />

        <div class="form-group">
            <label asp-for="Reservation.CustomerName">Customer</label>
            <input asp-for="Reservation.CustomerName" readonly />
        </div>

        <div class="form-group">
            <label asp-for="Reservation.StartDate">Start Date</label>
            <input asp-for="Reservation.StartDate" type="date" />
            <span asp-validation-for="Reservation.StartDate" class="field-validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Reservation.EndDate">End Date</label>
            <input asp-for="Reservation.EndDate" type="date" />
            <span asp-validation-for="Reservation.EndDate" class="field-validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Reservation.SiteId">Site</label>
            <input asp-for="Reservation.SiteId" />
            <span asp-validation-for="Reservation.SiteId" class="field-validation"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="save-btn">Save Changes</button>
        </div>

    </form>

    <form method="post" asp-page-handler="Cancel" class="cancel-form">
        <input type="hidden" name="id" value="@Model.Reservation.Id" />
        <button type="submit" class="cancel-btn">Cancel Reservation</button>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
