@page
@model RVPark_Team2.Pages.Admin.Fees.DeleteModel

@{
    ViewData["Title"] = "Delete Fee";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin-delete-fees.css" />
}

<div class="delete-container">

    <h1>Delete Fee</h1>

    <div class="delete-card">

        <p class="warning-text">Are you sure you want to delete this fee?</p>

        <div class="form-group">
            <label>Fee</label>
            <div class="readonly-field">
                @Model.Fee.FeeName
            </div>
        </div>

        <div class="form-group">
            <label>Amount</label>
            <div class="readonly-field">
                $@Model.Fee.Amount.ToString("F2")
            </div>
        </div>

        <div class="form-group">
            <label>Reservation</label>
            <div class="readonly-field">
                #@Model.Fee.ReservationId - @Model.Fee.Reservation?.CustomerName
            </div>
        </div>

        <form method="post" class="form-actions">
            <input type="hidden" asp-for="Fee.Id" />

            <button type="submit" class="delete-btn">Delete</button>

            <a asp-page="Index"
               asp-route-reservationId="@Model.Fee.ReservationId"
               class="cancel-btn">
                Cancel
            </a>
        </form>

    </div>

</div>