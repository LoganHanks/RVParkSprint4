@page
@model RVPark_Team2.Pages.Admin.Fees.CreateModel

@{
    ViewData["Title"] = "Create Fee";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin-create-fees.css" />
}

<div class="create-container">

    <h1>Add Fee</h1>

    <form method="post" class="create-form">

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <input type="hidden" asp-for="Fee.ReservationId" />

        <!-- NEW: Reservation display -->
        <div class="form-group">
            <label>Reservation</label>
            <div class="readonly-field">
                #@Model.Fee.ReservationId
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Fee.FeeName"></label>
            <input asp-for="Fee.FeeName" />
            <span asp-validation-for="Fee.FeeName"></span>
        </div>

        <div class="form-group">
            <label asp-for="Fee.Amount"></label>
            <input asp-for="Fee.Amount" type="number" step="0.01" min="0.01" />
            <span asp-validation-for="Fee.Amount"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="create-btn">Create Fee</button>

            <a asp-page="Index"
               asp-route-reservationId="@Model.Fee.ReservationId"
               class="cancel-btn">
                Cancel
            </a>
        </div>

    </form>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}